{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"],
    "noEmit": false
  },
  "include": ["vite.config.ts", "tailwind.config.ts"]
}
